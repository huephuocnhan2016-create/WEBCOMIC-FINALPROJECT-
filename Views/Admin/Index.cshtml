@model List<WEBCOMIC_FINALPROJECT_.Controllers.UserWithRolesViewModel>

<div class="container mt-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <div class="d-flex justify-content-between align-items-center bg-danger text-white p-3 rounded shadow-sm">
        <h2 class="mb-0"><i class="bi bi-people-fill"></i> Quản Lý Hệ Thống</h2>
        <div class="bg-white text-dark p-2 rounded">
            <form asp-action="UpdateVipConfig" method="post" class="d-flex align-items-center gap-2">
                <label class="fw-bold mb-0">Điểm đổi VIP:</label>
                <input type="number" name="points" value="@ViewBag.PointsToVip" class="form-control form-control-sm" style="width: 80px;" />
                <button type="submit" class="btn btn-sm btn-dark">Cập nhật</button>
            </form>
        </div>
    </div>

    <div class="card bg-dark text-white border-secondary mt-3 shadow">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0">
                <thead>
                    <tr class="text-secondary">
                        <th>Email / Username</th>
                        <th>Điểm Thưởng</th>
                        <th>Trạng thái VIP</th>
                        <th>Quyền Hiện Tại</th>
                        <th class="text-center">Thay Đổi Quyền</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="align-middle">
                                <div class="fw-bold">@item.User.Email</div>
                                <small class="text-muted">ID: @item.User.Id.Substring(0, 8)...</small>
                            </td>
                            <td class="align-middle">
                                <span class="badge bg-info text-dark">
                                    <i class="bi bi-star-fill"></i> @item.User.RewardPoints
                                </span>
                            </td>
                            <td class="align-middle">
                                @if (item.User.IsVip)
                                {
                                    <span class="badge bg-warning text-dark">VIP (Hết hạn: @item.User.VipExpiryDate?.ToShortDateString())</span>
                                }
                                else
                                {
                                    <span class="text-muted">Thường</span>
                                }
                            </td>
                            <td class="align-middle">
                                @foreach (var role in item.Roles)
                                {
                                    <span class="badge bg-primary">@role</span>
                                }
                            </td>
                            <td class="align-middle">
                                <form asp-action="ChangeRole" method="post" class="d-flex gap-2 justify-content-center">
                                    <input type="hidden" name="userId" value="@item.User.Id" />
                                    <select name="roleName" class="form-select form-select-sm bg-secondary text-white border-0" style="width: 130px;">
                                        @foreach (var role in ViewBag.AllRoles)
                                        {
                                            <option value="@role" selected="@(item.Roles.Contains(role))">@role</option>
                                        }
                                    </select>
                                    <button type="submit" class="btn btn-sm btn-primary px-3">
                                        <i class="bi bi-save"></i> Lưu
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>