@using Microsoft.AspNetCore.Identity
@using WEBCOMIC_FINALPROJECT_.Models
@inject UserManager<ApplicationUser> UserManager

@{
    // Fetch the current user once at the start to use their points
    var currentUser = await UserManager.GetUserAsync(User);
    var points = currentUser?.RewardPoints ?? 0;
}

<div class="container mt-4">
    <div class="row row-cols-2 row-cols-md-4 row-cols-lg-6 g-3">
        @foreach (var item in Model)
        {
            <div class="col">
                @* Wrapped in an anchor tag so the whole card is clickable *@
                <a asp-controller="MangaManager" asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none text-dark">
                    <div class="card h-100 position-relative shadow-sm border-0">
                        @if (item.IsVipOnly)
                        {
                            <span class="badge bg-warning text-dark position-absolute top-0 start-0 m-2">VIP</span>
                        }
                        <img src="@item.ImageUrl" class="card-img-top" style="aspect-ratio: 3/4; object-fit: cover;" alt="@item.Title">
                        <div class="card-body p-2">
                            <h6 class="card-title text-truncate mb-0">@item.Title</h6>
                            <small class="text-muted">Xem ngay</small>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
</div>

@* Sticky Navbar *@


@* Reader View (Optional part based on your snippet) *@
@if (ViewBag.CurrentImg != null)
{
    <div class="text-center bg-dark py-3">
        <img src="@ViewBag.CurrentImg" class="img-fluid" loading="lazy" style="max-width: 100%;">
    </div>
}

@* Fixed Bottom Reader Controls *@
<div class="fixed-bottom p-3 d-flex justify-content-center gap-2 bg-dark bg-opacity-75">
    <button class="btn btn-outline-light rounded-circle"><i class="bi bi-arrow-left"></i></button>
    <button class="btn btn-outline-light rounded-circle"><i class="bi bi-list"></i></button>
    <button class="btn btn-outline-light rounded-circle"><i class="bi bi-arrow-right"></i></button>
</div>