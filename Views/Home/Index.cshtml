@model IEnumerable<WEBCOMIC_FINALPROJECT_.Models.Manga>

<div class="container mt-4">
    @* --- 1. HIỂN THỊ THÔNG BÁO LỖI --- *@
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @* --- 2. PHẦN TRUYỆN HOT (TOP VIEW) --- *@
    @if (ViewBag.HotMangas != null)
    {
        <div class="mb-5">
            <h3 class="fw-bold mb-3"><i class="bi bi-fire text-danger"></i> Truyện Xem Nhiều Nhất</h3>
            <div class="d-flex flex-nowrap overflow-auto pb-2 gap-3" style="scrollbar-width: thin;">
                @foreach (var hot in (List<WEBCOMIC_FINALPROJECT_.Models.Manga>)ViewBag.HotMangas)
                {
                    <div class="card border-0 shadow-sm" style="min-width: 180px; max-width: 180px;">
                        <a asp-action="Details" asp-controller="Manga" asp-route-id="@hot.Id">
                            <img src="@hot.ImageUrl" class="card-img-top rounded" style="height: 240px; object-fit: cover;">
                        </a>
                        <div class="card-body p-2 text-center">
                            <h6 class="text-truncate mb-0">@hot.Title</h6>
                            <small class="text-muted"><i class="bi bi-eye"></i> @hot.ViewCount</small>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    @* --- 3. GỢI Ý THEO SỞ THÍCH --- *@
    @if (ViewBag.Recommended != null)
    {
        <div class="alert alert-light border-0 shadow-sm mb-5 p-4" style="background-color: #f0f7ff;">
            <h4 class="fw-bold text-primary mb-3"><i class="bi bi-hand-thumbs-up"></i> Có thể bạn sẽ thích</h4>
            <div class="row row-cols-2 row-cols-md-4 g-3">
                @foreach (var rec in (List<WEBCOMIC_FINALPROJECT_.Models.Manga>)ViewBag.Recommended)
                {
                    <div class="col">
                        <a asp-action="Details" asp-controller="Manga" asp-route-id="@rec.Id" class="text-decoration-none text-dark">
                            <div class="d-flex align-items-center bg-white p-2 rounded shadow-sm">
                                <img src="@rec.ImageUrl" style="width: 50px; height: 70px; object-fit: cover;" class="rounded me-2">
                                <div class="text-truncate"><strong>@rec.Title</strong></div>
                            </div>
                        </a>
                    </div>
                }
            </div>
        </div>
    }

    @* --- 4. DANH SÁCH TRUYỆN CHÍNH (PHÂN TRANG) --- *@
    <h3 class="fw-bold mb-4">📚 Danh sách truyện</h3>
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0 position-relative overflow-hidden card-manga">
                    @if (item.IsVipOnly)
                    {
                        <div class="position-absolute top-0 end-0 m-2" style="z-index: 10;">
                            <span class="badge bg-warning text-dark shadow-sm py-2 px-2">
                                <i class="bi bi-star-fill"></i> VIP
                            </span>
                        </div>
                    }

                    <a asp-controller="Manga" asp-action="Details" asp-route-id="@item.Id">
                        <img src="@item.ImageUrl" class="card-img-top"
                             style="height: 320px; object-fit: cover; transition: transform .3s;">
                    </a>

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title text-truncate mb-1" title="@item.Title">@item.Title</h5>
                        <div class="mb-3">
                            <span class="badge bg-info text-dark">@item.Genre?.Name</span>
                        </div>
                        <a asp-controller="Manga" asp-action="Details" asp-route-id="@item.Id"
                           class="btn @(item.IsVipOnly ? "btn-warning" : "btn-primary") mt-auto w-100 fw-bold">
                            @(item.IsVipOnly ? "Đọc truyện VIP" : "Đọc ngay")
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>

    @* --- 5. PHÂN TRANG --- *@
    @if (ViewBag.TotalPages > 1)
    {
        <nav aria-label="Page navigation" class="mt-5">
            <ul class="pagination justify-content-center shadow-sm">
                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@(ViewBag.CurrentPage - 1)"
                       asp-route-search="@ViewBag.Search">Trước</a>
                </li>

                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-page="@i"
                           asp-route-search="@ViewBag.Search">@i</a>
                    </li>
                }

                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@(ViewBag.CurrentPage + 1)"
                       asp-route-search="@ViewBag.Search">Sau</a>
                </li>
            </ul>
        </nav>
    }
</div>

@* Thêm CSS thủ công để làm mượt hiệu ứng *@
<style>
    .card-manga img:hover {
        transform: scale(1.05);
    }

    .overflow-auto::-webkit-scrollbar {
        height: 6px;
    }

    .overflow-auto::-webkit-scrollbar-thumb {
        background: #ccc;
        border-radius: 10px;
    }
</style>