@model IEnumerable<WEBCOMIC_FINALPROJECT_.Models.Manga>

<div class="container mt-4">
    @* Hiển thị thông báo lỗi nếu có (Ví dụ: khi người dùng không có quyền xem truyện VIP) *@
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0 position-relative overflow-hidden">
                    @* 1. HIỂN THỊ NHÃN VIP *@
                    @if (item.IsVipOnly)
                    {
                        <div class="position-absolute top-0 end-0 m-2" style="z-index: 10;">
                            <span class="badge bg-warning text-dark shadow-sm py-2 px-2">
                                <i class="bi bi-star-fill"></i> VIP
                            </span>
                        </div>
                    }

                    @* 2. ẢNH BÌA (Hỗ trợ cả link URL và ảnh tải lên) *@
                    <a asp-controller="MangaManager" asp-action="Details" asp-route-id="@item.Id">
                        <img src="@item.ImageUrl" class="card-img-top"
                             style="height: 320px; object-submit: cover; transition: transform .3s;"
                             onmouseover="this.style.transform='scale(1.05)'"
                             onmouseout="this.style.transform='scale(1)'">
                    </a>

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title text-truncate mb-1" title="@item.Title">@item.Title</h5>

                        <div class="mb-3">
                            <span class="badge bg-info text-dark">@item.Genre?.Name</span>
                        </div>

                        <a asp-controller="MangaManager" asp-action="Details" asp-route-id="@item.Id"
                           class="btn @(item.IsVipOnly ? "btn-warning" : "btn-primary") mt-auto w-100 fw-bold">
                            @(item.IsVipOnly ? "Đọc truyện VIP" : "Đọc ngay")
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>

    @* 3. PHÂN TRANG (Giữ nguyên logic của bạn nhưng tối ưu hiển thị) *@
    @if (ViewBag.TotalPages > 1)
    {
        <nav aria-label="Page navigation" class="mt-5">
            <ul class="pagination justify-content-center shadow-sm">
                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@(ViewBag.CurrentPage - 1)"
                       asp-route-search="@ViewBag.Search">Trước</a>
                </li>

                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-page="@i"
                           asp-route-search="@ViewBag.Search">@i</a>
                    </li>
                }

                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@(ViewBag.CurrentPage + 1)"
                       asp-route-search="@ViewBag.Search">Sau</a>
                </li>
            </ul>
        </nav>
    }
</div>