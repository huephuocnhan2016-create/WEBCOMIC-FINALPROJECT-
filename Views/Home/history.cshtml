@using WEBCOMIC_FINALPROJECT_.Models
@model IEnumerable<WEBCOMIC_FINALPROJECT_.Models.ReadingHistory>

@{
    ViewData["Title"] = "Lịch sử đọc truyện";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <h2 class="text-white mb-4">
        <i class="bi bi-clock-history text-warning"></i> Lịch sử đọc truyện
    </h2>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info text-center bg-dark text-white border-info shadow">
            <i class="bi bi-info-circle fs-3"></i>
            <p class="mb-0 mt-2">Bạn chưa đọc truyện nào.</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-info mt-3">
                <i class="bi bi-book"></i> Khám phá ngay
            </a>
        </div>
    }
    else
    {
        <div class="list-group">
            @* Sửa ReadAt thành LastRead *@
            @foreach (var history in Model.OrderByDescending(h => h.LastRead))
            {
                @* Sử dụng trực tiếp history.Manga thay vì qua Chapter *@
                var manga = history.Manga;

                if (manga != null)
                {
                    <a asp-controller="MangaManager" asp-action="Details" asp-route-id="@manga.Id"
                       class="list-group-item list-group-item-action bg-dark text-white border-secondary mb-2 rounded shadow-sm">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <i class="bi bi-journal-bookmark-fill text-warning me-2"></i>
                                <strong>@manga.Title</strong>
                            </div>
                            <small class="text-muted">
                                @* Sửa ReadAt thành LastRead *@
                                <i class="bi bi-clock"></i> @history.LastRead.ToString("dd/MM/yyyy HH:mm")
                            </small>
                        </div>
                        <div class="mt-1">
                            <small class="text-info">
                                <i class="bi bi-eye"></i> Tiếp tục theo dõi truyện này
                            </small>
                        </div>
                    </a>
                }
                else
                {
                    <div class="list-group-item bg-dark text-white border-danger mb-2 rounded opacity-75">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <i class="bi bi-exclamation-triangle text-danger me-2"></i>
                                <span>Truyện đã bị xóa hoặc không tồn tại (ID: @history.MangaId)</span>
                            </div>
                            <small class="text-muted">@history.LastRead.ToString("dd/MM/yyyy HH:mm")</small>
                        </div>
                    </div>
                }
            }
        </div>

        <div class="card bg-dark text-white mt-4 border-secondary shadow">
            <div class="card-body">
                <h5 class="text-info mb-3">
                    <i class="bi bi-graph-up"></i> Thống kê cá nhân
                </h5>
                <div class="text-center">
                    <p class="text-muted mb-1 small">Tổng số bộ truyện đã xem</p>
                    <h3 class="text-warning fw-bold">@Model.Count()</h3>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .list-group-item {
        transition: all 0.25s ease;
        border-left: 4px solid transparent !important;
    }

        .list-group-item:hover {
            transform: translateX(10px);
            box-shadow: 0 4px 15px rgba(255, 193, 7, 0.15);
            border-left: 4px solid #ffc107 !important;
            background-color: #2c2c2c !important;
        }
</style>