<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MANGA-Z</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        /* Tùy chỉnh màu tối cho toàn bộ trang */
        body {
            background-color: #0b0c0d;
            color: white;
        }

        .navbar-custom {
            background-color: #000000;
            border-bottom: 1px solid #333;
        }

        .search-bar {
            background: #1a1a1a;
            border: 1px solid #444;
            color: white;
            border-radius: 20px;
            padding: 5px 20px;
            width: 300px;
        }

            .search-bar:focus {
                background: #222;
                color: white;
                outline: none;
                border-color: #ff0000;
            }
    </style>
</head>

@using Microsoft.AspNetCore.Identity
@using WEBCOMIC_FINALPROJECT_.Models
@inject UserManager<ApplicationUser> UserManager

<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark navbar-custom shadow-sm py-2">
            <div class="container">
                <a class="navbar-brand fw-bold text-danger fs-3" asp-area="" asp-controller="Home" asp-action="Index">MANGA-Z</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item"><a class="nav-link text-white" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                        <li class="nav-item"><a class="nav-link text-danger fw-bold" asp-controller="Quiz" asp-action="Index">Daily Quiz</a></li>

                        @if (User.IsInRole("Author"))
                        {
                            <li class="nav-item"><a class="nav-link text-success" asp-controller="MangaManager" asp-action="Create">Đăng truyện</a></li>
                        }
                        @if (User.IsInRole("Moderator"))
                        {
                            <li class="nav-item"><a class="nav-link text-warning" asp-controller="MangaManager" asp-action="PendingList">Duyệt bài</a></li>
                        }
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Index">Quản lý User</a></li>
                        }
                    </ul>

                    <form class="d-flex mx-auto d-none d-lg-block">
                        <input class="search-bar" type="search" placeholder="Tìm tên truyện..." aria-label="Search">
                    </form>

                    @* Identity Login Partial - Cái này sẽ hiện Login/Register ở góc phải *@
                    <div class="ms-lg-3">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-4">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    @* Mobile Navigation Bar - Chỉ hiện trên điện thoại *@
    <div class="fixed-bottom d-md-none bg-dark border-top border-secondary p-2 shadow-lg">
        <div class="d-flex justify-content-around text-center">
            <a href="/" class="text-white text-decoration-none small">
                <i class="bi bi-house-door fs-4"></i><br>Home
            </a>
            <a href="/Quiz" class="text-danger text-decoration-none small">
                <i class="bi bi-controller fs-4"></i><br>Quiz
            </a>
            @if (User.Identity.IsAuthenticated)
            {
                <a href="/Identity/Account/Manage" class="text-white text-decoration-none small">
                    <i class="bi bi-person fs-4"></i><br>Tôi
                </a>
            }
            else
            {
                <a href="/Identity/Account/Login" class="text-white text-decoration-none small">
                    <i class="bi bi-box-arrow-in-right fs-4"></i><br>Login
                </a>
            }
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        $(document).ready(function() {
            @if (TempData["Success"] != null)
            {
                <text>toastr.success('@TempData["Success"]');</text>
            }
            @if (TempData["Error"] != null)
            {
                <text>toastr.error('@TempData["Error"]');</text>
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>