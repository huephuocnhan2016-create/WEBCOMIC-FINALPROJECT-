@using Microsoft.AspNetCore.Identity
@using WEBCOMIC_FINALPROJECT_.Models

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav align-items-center">
    @if (SignInManager.IsSignedIn(User))
    {
        // FIX: Bỏ ký tự @ trước dấu { vì chúng ta đang ở trong block @if rồi
        {
            var user = await UserManager.GetUserAsync(User);

            <li class="nav-item me-3">
                <span class="nav-link text-warning fw-bold">
                    <i class="bi bi-coin"></i> Điểm: @(user?.RewardPoints ?? 0)
                </span>
            </li>

            <li class="nav-item me-2">
                <a class="btn btn-outline-warning btn-sm" asp-controller="Quiz" asp-action="Index">
                    <i class="bi bi-controller"></i> Daily Quiz
                </a>
            </li>

            <li class="nav-item">
                <a id="manage" class="nav-link text-white" asp-area="Identity" asp-page="/Account/Manage/Index" title="Quản lý tài khoản">
                    Chào, @UserManager.GetUserName(User)!
                </a>
            </li>

            <li class="nav-item">
                <form id="logoutForm" class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                    <button id="logout" type="submit" class="nav-link btn btn-link text-secondary border-0">Thoát</button>
                </form>
            </li>
        }
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link text-white" id="register" asp-area="Identity" asp-page="/Account/Register">Đăng ký</a>
        </li>
        <li class="nav-item">
            <a class="nav-link btn btn-primary btn-sm ms-lg-2 px-3" id="login" asp-area="Identity" asp-page="/Account/Login">Đăng nhập</a>
        </li>
    }
</ul>