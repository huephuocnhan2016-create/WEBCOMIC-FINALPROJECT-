@model Manga

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Đăng truyện mới</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <div class="mb-3">
                            <label class="form-label">Tên bộ truyện</label>
                            <input asp-for="Title" class="form-control" placeholder="Nhập tên truyện..." required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Link ảnh bìa (URL)</label>
                            <input asp-for="ImageUrl" class="form-control" placeholder="https://..." required />
                            <small class="text-muted">Lưu ý: Ảnh này sẽ được dùng làm câu hỏi trong Daily Quiz.</small>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Thể loại</label>
                            <select asp-for="GenreId" class="form-select" asp-items="@ViewBag.GenreList">
                                <option value="">-- Chọn thể loại --</option>
                            </select>
                        </div>
                        <div class="form-check mb-3">
                            <input asp-for="IsVipOnly" class="form-check-input" type="checkbox" id="vipCheck">
                            <label class="form-check-label" for="vipCheck">Đây là truyện VIP</label>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Gửi yêu cầu duyệt</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>