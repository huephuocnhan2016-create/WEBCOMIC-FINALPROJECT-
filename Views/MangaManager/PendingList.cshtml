@model IEnumerable<Manga>

<div class="container mt-4">
    <h2 class="mb-4"><i class="bi bi-shield-check"></i> Danh sách truyện chờ duyệt</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-light text-center">Hiện không có truyện nào cần duyệt.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Ảnh</th>
                        <th>Tên truyện</th>
                        <th>Thể loại</th>
                        <th>Tác giả (ID)</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><img src="@item.ImageUrl" style="width: 60px; height: 80px; object-fit: cover;" class="rounded"></td>
                            <td><strong>@item.Title</strong></td>
                            <td>@item.Genre?.Name</td>
                            <td><small>@item.AuthorId</small></td>
                            <td>
                                <form asp-action="Approve" asp-route-id="@item.Id" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-success btn-sm">
                                        <i class="bi bi-check-lg"></i> Duyệt bài
                                    </button>
                                </form>
                                <a href="#" class="btn btn-outline-danger btn-sm">Xóa</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>