@model WEBCOMIC_FINALPROJECT_.Models.Manga
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager

@{
    var user = await UserManager.GetUserAsync(User);
    // Chỉ là Owner nếu ID người dùng trùng với AuthorId của truyện
    bool isOwner = user != null && Model.AuthorId == user.Id;
    bool isAdminOrMod = User.IsInRole("Admin") || User.IsInRole("Moderator");
}

<div class="container mt-4 text-white">
    <div class="row">
        <div class="col-md-4">
            <img src="@Model.ImageUrl" class="img-fluid rounded shadow w-100">
            <div class="d-grid gap-2 mt-3">
                @* CHỈ AUTHOR MỚI ĐƯỢC THÊM CHƯƠNG *@
                @if (isOwner)
                {
                    <a asp-controller="MangaManager" asp-action="Create" asp-route-mangaId="@Model.Id" class="btn btn-success">
                        <i class="bi bi-plus-circle"></i> THÊM CHƯƠNG MỚI
                    </a>
                }
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-light">Quay lại</a>
            </div>
        </div>

        <div class="col-md-8">
            @if (isOwner)
            {
                <span class="badge bg-success mb-2">Truyện của bạn</span>
            }
            <h1 class="text-warning">@Model.Title</h1>
            <p class="bg-dark p-3 border border-secondary rounded">@Model.Description</p>

            <h4 class="mt-4">Danh sách chương</h4>
            <div class="list-group">
                @foreach (var ch in Model.Chapters.OrderByDescending(c => c.Id))
                {
                    <div class="list-group-item list-group-item-action bg-dark text-white border-secondary d-flex justify-content-between align-items-center">
                        <a asp-controller="MangaManager" asp-action="Read" asp-route-id="@ch.Id" class="text-info text-decoration-none flex-grow-1">
                            @ch.Title <span class="badge bg-primary ms-2">@ch.Images.Count ảnh</span>
                        </a>

                        @if (isOwner || isAdminOrMod)
                        {
                            <form asp-controller="MangaManager" asp-action="DeleteChapter" asp-route-id="@ch.Id" method="post" onsubmit="return confirm('Bạn chắc chắn muốn xóa chương này chứ?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger border-0">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>