@model WEBCOMIC_FINALPROJECT_.Models.Chapter
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager

<div class="container mt-4 text-center">
    @if (ViewBag.CanRead == false)
    {
        <div class="card border-warning bg-dark text-white mx-auto shadow-lg my-5" style="max-width: 650px; border-radius: 20px;">
            <div class="card-body py-5">
                <div class="mb-4">
                    <i class="bi bi-shield-lock-fill text-warning" style="font-size: 5rem;"></i>
                </div>
                <h2 class="card-title fw-bold text-uppercase">Nội dung giới hạn VIP</h2>
                <p class="card-text fs-5 px-4 mb-4">
                    Bạn đang cố gắng xem chương thuộc bộ truyện <span class="text-warning fw-bold">VIP</span>.
                    Vui lòng nâng cấp tài khoản để ủng hộ tác giả và tiếp tục đọc.
                </p>

                <div class="d-grid gap-3 col-10 mx-auto">
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <form asp-controller="User" asp-action="RedeemVip" method="post">
                            <button type="submit" class="btn btn-warning btn-lg fw-bold shadow w-100">
                                <i class="bi bi-gem"></i> ĐỔI 10 ĐIỂM LẤY 7 NGÀY VIP
                            </button>
                        </form>
                    }
                    else
                    {
                        <a href="/Identity/Account/Login?ReturnUrl=@Context.Request.Path" class="btn btn-primary btn-lg fw-bold">
                            <i class="bi bi-person-fill-lock"></i> ĐĂNG NHẬP ĐỂ ĐỌC TIẾP
                        </a>
                    }

                    <a asp-action="Details" asp-route-id="@Model.MangaId" class="btn btn-outline-light">
                        <i class="bi bi-arrow-left"></i> Quay lại trang chi tiết
                    </a>
                </div>

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger mt-3">@TempData["Error"]</div>
                }
            </div>
        </div>
    }
    else
    {
        <h2 class="text-warning fw-bold">@Model.Manga.Title - @Model.Title</h2>

        <div class="d-flex justify-content-center gap-3 my-4">
            @if (ViewBag.PrevId != null)
            {
                <a asp-action="Read" asp-route-id="@ViewBag.PrevId" class="btn btn-primary shadow-sm">
                    <i class="bi bi-arrow-left"></i> Chương trước
                </a>
            }
            else
            {
                <button class="btn btn-secondary" disabled>Đầu danh sách</button>
            }

            <a asp-action="Details" asp-route-id="@Model.MangaId" class="btn btn-outline-light px-4">Mục lục</a>

            @if (ViewBag.NextId != null)
            {
                <a asp-action="Read" asp-route-id="@ViewBag.NextId" class="btn btn-primary shadow-sm">
                    Chương sau <i class="bi bi-arrow-right"></i>
                </a>
            }
            else
            {
                <button class="btn btn-secondary" disabled>Hết chương</button>
            }
        </div>

        <div class="manga-content mx-auto shadow" style="max-width: 850px; background-color: #000; padding: 10px;">
            @if (Model.Images != null && Model.Images.Any())
            {
                @foreach (var img in Model.Images.OrderBy(i => i.Id))
                {
                    <img src="@img.Url" class="img-fluid w-100 mb-1" alt="page" loading="lazy" />
                }
            }
            else
            {
                <div class="alert alert-secondary my-5">Chương này hiện chưa có nội dung ảnh.</div>
            }
        </div>

        <div class="d-flex justify-content-center gap-3 my-5 pb-5">
            @if (ViewBag.PrevId != null)
            {
                <a asp-action="Read" asp-route-id="@ViewBag.PrevId" class="btn btn-outline-primary px-4">Trước</a>
            }
            @if (ViewBag.NextId != null)
            {
                <a asp-action="Read" asp-route-id="@ViewBag.NextId" class="btn btn-primary px-5 fw-bold shadow">CHƯƠNG TIẾP THEO</a>
            }
        </div>

        @* --- PHẦN ĐÁNH GIÁ CHƯƠNG --- *@
        <div class="chapter-rating text-center my-4 p-4 rounded bg-dark border border-secondary shadow-sm mx-auto" style="max-width: 600px;">
            <p class="text-white fs-5 mb-2 fw-bold">Bạn đánh giá chương này thế nào?</p>
            <div class="d-flex justify-content-center align-items-center mb-2">
                <span class="badge bg-warning text-dark fs-6 me-3">
                    ⭐ @(ViewBag.AvgChapterRating?.ToString("0.0") ?? "0.0")
                </span>
                <div class="star-rating d-inline-flex">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <form asp-controller="MangaManager" asp-action="RateChapter" method="post" style="display:inline;" class="m-0">
                            <input type="hidden" name="chapterId" value="@Model.Id" />
                            <input type="hidden" name="score" value="@i" />
                            <button type="submit" class="btn btn-link p-1 border-0 shadow-none" title="Đánh giá @i sao">
                                <i class="bi @(i <= (ViewBag.UserChapterRating ?? 0) ? "bi-star-fill text-warning" : "bi-star text-secondary") fs-3"></i>
                            </button>
                        </form>
                    }
                </div>
            </div>
            @if (ViewBag.UserChapterRating != null && ViewBag.UserChapterRating > 0)
            {
                <small class="text-success mt-2 d-block"><i class="bi bi-check-circle-fill"></i> Bạn đã đánh giá @ViewBag.UserChapterRating sao.</small>
            }
        </div>

        @* --- PHẦN BÌNH LUẬN MANGA MANAGER --- *@
        <hr class="border-secondary mt-5">
        <div class="container mt-4 pb-5 text-start" style="max-width: 850px;">
            <h4 class="text-white mb-4"><i class="bi bi-chat-dots"></i> Bình luận chương</h4>

            @if (User.Identity.IsAuthenticated)
            {
                <form asp-controller="MangaManager" asp-action="PostComment" method="post" class="mb-4 text-center">
                    <input type="hidden" name="chapterId" value="@Model.Id" />
                    <div class="form-group">
                        <textarea name="content" class="form-control bg-dark text-white border-secondary"
                          rows="3" placeholder="Chia sẻ cảm nghĩ của bạn..."></textarea>
                    </div>
                    <div class="text-end">
                        <button type="submit" class="btn btn-primary mt-2 px-4 shadow">Gửi bình luận</button>
                    </div>
                </form>
            }
            else
            {
                <div class="alert alert-secondary bg-dark text-light border-secondary">
                    Vui lòng <a asp-area="Identity" asp-page="/Account/Login" class="text-info fw-bold">đăng nhập</a> để bình luận.
                </div>
            }

            <div class="comment-list mt-4">
                @if (ViewBag.Comments != null && ((IEnumerable<dynamic>)ViewBag.Comments).Any())
                {
                    foreach (var comment in ViewBag.Comments)
                    {
                        <div class="d-flex mb-3 p-3 bg-secondary bg-opacity-10 rounded border-start border-primary border-4">
                            <div class="flex-grow-1">
                                <div class="d-flex justify-content-between mb-1">
                                    <strong class="text-info">@comment.User?.UserName</strong>
                                    <small class="text-muted">@comment.CreatedAt.ToString("HH:mm dd/MM/yyyy")</small>
                                </div>
                                <p class="mb-0 text-light">@comment.Content</p>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted fst-italic">Chưa có bình luận nào. Hãy là người đầu tiên!</p>
                }
            </div>
        </div>
    }
</div>