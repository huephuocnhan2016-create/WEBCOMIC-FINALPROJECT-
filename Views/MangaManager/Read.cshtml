@model WEBCOMIC_FINALPROJECT_.Models.Chapter
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager

<div class="container mt-4 text-center">
    @if (ViewBag.CanRead == false)
    {
        <div class="card border-warning bg-dark text-white mx-auto shadow-lg my-5" style="max-width: 650px; border-radius: 20px;">
            <div class="card-body py-5">
                <div class="mb-4">
                    <i class="bi bi-shield-lock-fill text-warning" style="font-size: 5rem;"></i>
                </div>
                <h2 class="card-title fw-bold text-uppercase">Nội dung giới hạn VIP</h2>
                <p class="card-text fs-5 px-4 mb-4">
                    Bạn đang cố gắng xem chương thuộc bộ truyện <span class="text-warning fw-bold">VIP</span>.
                    Vui lòng nâng cấp tài khoản để ủng hộ tác giả và tiếp tục đọc.
                </p>

                <div class="d-grid gap-3 col-10 mx-auto">
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <form asp-controller="User" asp-action="RedeemVip" method="post">
                            <button type="submit" class="btn btn-warning btn-lg fw-bold shadow w-100">
                                <i class="bi bi-gem"></i> ĐỔI 10 ĐIỂM LẤY 7 NGÀY VIP
                            </button>
                        </form>
                    }
                    else
                    {
                        <a href="/Identity/Account/Login?ReturnUrl=@Context.Request.Path" class="btn btn-primary btn-lg fw-bold">
                            <i class="bi bi-person-fill-lock"></i> ĐĂNG NHẬP ĐỂ ĐỌC TIẾP
                        </a>
                    }

                    <a asp-action="Details" asp-route-id="@Model.MangaId" class="btn btn-outline-light">
                        <i class="bi bi-arrow-left"></i> Quay lại trang chi tiết
                    </a>
                </div>

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger mt-3">@TempData["Error"]</div>
                }
            </div>
        </div>
    }
    else
    {
        <h2 class="text-warning fw-bold">@Model.Manga.Title - @Model.Title</h2>

        <div class="d-flex justify-content-center gap-3 my-4">
            @if (ViewBag.PrevId != null)
            {
                <a asp-action="Read" asp-route-id="@ViewBag.PrevId" class="btn btn-primary shadow-sm">
                    <i class="bi bi-arrow-left"></i> Chương trước
                </a>
            }
            else
            {
                <button class="btn btn-secondary" disabled>Đầu danh sách</button>
            }

            <a asp-action="Details" asp-route-id="@Model.MangaId" class="btn btn-outline-light px-4">Mục lục</a>

            @if (ViewBag.NextId != null)
            {
                <a asp-action="Read" asp-route-id="@ViewBag.NextId" class="btn btn-primary shadow-sm">
                    Chương sau <i class="bi bi-arrow-right"></i>
                </a>
            }
            else
            {
                <button class="btn btn-secondary" disabled>Hết chương</button>
            }
        </div>

        <div class="manga-content mx-auto shadow" style="max-width: 850px; background-color: #000; padding: 10px;">
            @if (Model.Images != null && Model.Images.Any())
            {
                @foreach (var img in Model.Images.OrderBy(i => i.Id))
                {
                    <img src="@img.Url" class="img-fluid w-100 mb-1" alt="page" loading="lazy" />
                }
            }
            else
            {
                <div class="alert alert-secondary my-5">Chương này hiện chưa có nội dung ảnh.</div>
            }
        </div>

        <div class="d-flex justify-content-center gap-3 my-5 pb-5">
            @if (ViewBag.PrevId != null)
            {
                <a asp-action="Read" asp-route-id="@ViewBag.PrevId" class="btn btn-outline-primary px-4">Trước</a>
            }
            @if (ViewBag.NextId != null)
            {
                <a asp-action="Read" asp-route-id="@ViewBag.NextId" class="btn btn-primary px-5 fw-bold shadow">CHƯƠNG TIẾP THEO</a>
            }
        </div>
    }
</div>